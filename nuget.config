<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Includi la cartella locale 'libs' come sorgente pacchetti -->
    <add key="local-libs" value="./libs" />
    <!-- Mantieni comunque il caricamento dai server ufficiali NuGet -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
